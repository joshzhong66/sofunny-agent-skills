# NewAPI base URL (without trailing slash)
NEWAPI_BASE_URL=https://api.newapi.com

# Default model name for Seedance 2.0
SEEDANCE_MODEL=seedance-2.0

# LLM model for AI prompt expansion (also via NewAPI)
LLM_MODEL=gpt-4o-mini

# Server port
PORT=3000

# Optional FTP mirror directory for generated videos
FTP_MIRROR_DIR=/data/ftp/seedance-studio

# Optional public FTP URL prefix for mirrored videos
FTP_PUBLIC_BASE_URL=ftp://10.20.3.69/seedance-studio
